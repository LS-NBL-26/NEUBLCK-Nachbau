---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const members = (await getCollection('team', ({ data }) => !data.draft)).sort(
  (a, b) => a.data.order - b.data.order
);
---

<BaseLayout title="Team – NEUBLCK">
  <section class="mx-auto max-w-5xl px-4 py-16">
    <h1 class="mb-10 text-3xl font-bold tracking-tight">Team</h1>
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-3">
      {
        members.map((member) => (
          <div class="text-center">
            {member.data.photo && (
              <Image
                src={member.data.photo}
                alt={member.data.name}
                class="mx-auto mb-4 h-40 w-40 rounded-full object-cover"
              />
            )}
            <h2 class="text-lg font-semibold">{member.data.name}</h2>
            <p class="text-sm text-neutral-500">{member.data.role}</p>
          </div>
        ))
      }
    </div>
  </section>
</BaseLayout>
