---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const dateFormat = new Intl.DateTimeFormat('de-DE', { dateStyle: 'long' });
---

<BaseLayout title="Blog – NEUBLCK">
  <section class="mx-auto max-w-3xl px-4 py-16">
    <h1 class="mb-10 text-3xl font-bold tracking-tight">Blog</h1>
    <ul class="space-y-10">
      {
        posts.map((post) => (
          <li>
            <a href={`/blog/${post.id}/`} class="group block">
              <time class="text-sm text-neutral-500" datetime={post.data.pubDate.toISOString()}>
                {dateFormat.format(post.data.pubDate)}
              </time>
              <h2 class="mt-1 text-xl font-semibold group-hover:underline">{post.data.title}</h2>
              {post.data.description && (
                <p class="mt-2 text-neutral-600">{post.data.description}</p>
              )}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
