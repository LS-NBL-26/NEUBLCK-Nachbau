---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import IntroText from "../components/IntroText.astro";

// Zuordnung: Typ-Name aus home.md → Komponente
const sectionComponents = {
  introtext: IntroText,
};

const home = await getEntry("pages", "home");
if (!home) {
  throw new Error(
    "Inhalt 'home' nicht gefunden – existiert src/content/pages/home.md?",
  );
}
const { sections } = home.data;
---

<BaseLayout title="NEUBLCK – Startseite" description={home.data.description}>
  <main>
    {
      sections.map((section) => {
        const Component = sectionComponents[section.type];
        return Component ? <Component {...section} /> : null;
      })
    }
  </main>
</BaseLayout>