---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";
import IntroText from "../components/IntroText.astro";
import HeroVideo from "../components/HeroVideo.astro";

// Zuordnung: Typ-Name aus home.md → Komponente
const sectionComponents: Record<string, any> = {
  introtext: IntroText,
  herovideo: HeroVideo
};

const home = await getEntry("pages", "home");
if (!home) {
  throw new Error(
    "Inhalt 'home' nicht gefunden – existiert src/content/pages/home.md?",
  );
}
const { sections } = home.data;
---

<BaseLayout title="NEUBLCK – Startseite" description={home.data.description}>
  <main
    data-editable="array"
    data-prop="sections"
    data-id-key="type"
    data-component-key="type"
  >
    {
      sections.map((section: any) => {
        const Component = sectionComponents[section.type];
        return Component ? (
          <div
            data-editable="array-item"
            data-id={section.type}
            data-component={section.type}
          >
            <Component {...section} />
          </div>
        ) : null;
      })
    }
  </main>
</BaseLayout>
