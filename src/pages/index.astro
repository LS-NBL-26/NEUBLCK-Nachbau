---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Neueste Blog-Beiträge für einen Teaser auf der Startseite.
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout title="NEUBLCK – Startseite">
  <section class="mx-auto max-w-5xl px-4 py-24 text-center">
    <h1 class="text-4xl font-bold tracking-tight sm:text-6xl">NEUBLCK</h1>
    <p class="mx-auto mt-6 max-w-2xl text-lg text-neutral-600">
      Startseite mit Astro & CloudCannon nachgebaut. Hier beginnt der Nachbau –
      ersetze diesen Bereich mit deinen eigenen Inhalten.
    </p>
  </section>

  {
    posts.length > 0 && (
      <section class="mx-auto max-w-5xl px-4 pb-24">
        <h2 class="mb-8 text-2xl font-semibold">Aus dem Blog</h2>
        <div class="grid gap-8 sm:grid-cols-3">
          {posts.map((post) => (
            <a href={`/blog/${post.id}/`} class="group block">
              <h3 class="text-lg font-medium group-hover:underline">{post.data.title}</h3>
              <p class="mt-2 text-sm text-neutral-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )
  }
</BaseLayout>
