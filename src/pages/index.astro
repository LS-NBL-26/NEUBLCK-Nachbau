---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getEntry } from "astro:content";

const home = await getEntry("pages", "home");
if (!home) {
  throw new Error(
    "Inhalt 'home' nicht gefunden – existiert src/content/pages/home.md?",
  );
}
const { hero } = home.data;

// Unterstrichenes (<u>) für die Anzeige in semantisches <mark> umwandeln:
const heroHtml = hero.text.replace(/<(\/?)u\b[^>]*>/g, "<$1mark>");
---

<BaseLayout title="NEUBLCK – Startseite" description={home.data.description}>
  <header class="header">
    <span class="logo">_NEUBLCK</span>
    <button class="menu-btn">
      <i class="fa-solid fa-bars"></i> Menü
    </button>
  </header>

  <main class="hero">
    <div class="hero_row">
      <i class="fa-solid fa-arrow-right hero_arrow"></i>
      <div
        class="hero__text"
        data-editable="text"
        data-prop="hero.text"
        data-type="block"
        set:html={heroHtml}
      />
    </div>

    <div class="buttons">
      {
        hero.buttons.map((btn, i) => (
          <a
            href={btn.href}
            class={
              btn.style === "primary"
                ? "btn btn-primary"
                : "btn btn-secondary"
            }
          >
            <i class="fa-solid fa-arrow-right" />
            <editable-text data-prop={`hero.buttons[${i}].label`}>
              {btn.label}
            </editable-text>
          </a>
        ))
      }
    </div>
  </main>
</BaseLayout>
