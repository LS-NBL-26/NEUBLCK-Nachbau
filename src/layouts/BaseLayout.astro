---
import { SEO } from "astro-seo";
import "@fortawesome/fontawesome-free/css/all.min.css"; // Font Awesome 7 (lokal)
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const { title = "NEUBLCK", description = "NEUBLCK – Startseite" } = Astro.props;
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/siteicon.png" />
    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title: title,
          type: "website",
          image: "/siteicon.png",
        },
      }}
    />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
    <script>
      // @ts-ignore – "inEditorMode" wird von @cloudcannon/editable-regions zur Laufzeit gesetzt
      if (window.inEditorMode) {
        import("../scripts/register-components.js").catch((error) => {
          console.warn("Registrierung für CloudCannon fehlgeschlagen:", error);
        });
      }
    </script>
  </body>
</html>
